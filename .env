# API base URL — baked into the client bundle at build time (VITE_ prefix required)
# VITE_API_BASE=https://be-zalo-mini-app.vercel.app/api
VITE_API_BASE=http://localhost:3000/api


# Cloudinary — upload trực tiếp từ browser (unsigned preset)
VITE_CLOUDINARY_CLOUD_NAME=diuwaesix
VITE_CLOUDINARY_UPLOAD_PRESET=happmall
